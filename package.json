{
  "name": "wechat-agent-bridge",
  "version": "0.4.0",
  "private": false,
  "type": "module",
  "description": "Run Codex and Claude Code from WeChat with resumable sessions, durable queues, safe workspaces, media, and explicit artifact delivery.",
  "keywords": [
    "wechat",
    "codex",
    "claude-code",
    "coding-agent",
    "ai-agent",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chenshize/wechat-agent-bridge.git"
  },
  "homepage": "https://github.com/chenshize/wechat-agent-bridge#readme",
  "bugs": {
    "url": "https://github.com/chenshize/wechat-agent-bridge/issues"
  },
  "bin": {
    "wechat-agent-bridge": "./src/cli.js"
  },
  "scripts": {
    "login": "node ./src/cli.js login",
    "run": "node ./src/cli.js run",
    "doctor": "node ./src/cli.js doctor",
    "test": "node --test",
    "check": "node --check src/cli.js && node --check src/bridge.js && node --test"
  },
  "dependencies": {
    "qrcode-terminal": "0.12.0"
  },
  "engines": {
    "node": ">=22"
  }
}
